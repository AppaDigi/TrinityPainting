{
  "name": "nextjs-boilerplate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build",
    "deps:check": "npm outdated || true",
    "deps:update": "npm update",
    "deps:update:latest": "npx npm-check-updates -u && npm install"
  },
  "dependencies": {
